pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Run FS Check') {
      steps {
        script {
          def out = sh(script: 'ansible-playbook -i inventory/hosts.ini playbooks/run_fs_check.yml', returnStdout: true).trim()
          writeFile file: 'fs_report.json', text: out
          echo out
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'fs_report.json', allowEmptyArchive: true
    }
  }
}
