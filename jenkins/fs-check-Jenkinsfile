pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Run FS Check') {
            steps {
                // We bypass Ansible's pathing and write the output directly into the workspace root
                sh 'python3 scripts/fs_check.py > fs_report.json || true'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'fs_report.json', allowEmptyArchive: false
        }
    }
}
