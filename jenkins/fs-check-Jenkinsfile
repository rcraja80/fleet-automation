pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Run FS Check') {
            steps {
                // By adding || true, we prevent Jenkins from stopping if Ansible passes exit code 2
                sh 'ansible-playbook -i inventory/hosts.ini playbooks/run_fs_check.yml || true'
            }
        }
    }

    post {
        always {
            // Target the explicitly generated root-level file
            archiveArtifacts artifacts: 'fs_report.json', allowEmptyArchive: false
        }
    }
}
